# Environment Variables Template
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://postgres.wugialmyzqtbjvkrdjvb:a7i+CV.2cXbeaN$@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
